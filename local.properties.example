## Copy this file to local.properties and fill in your values.
## local.properties is gitignored and must NEVER be committed to version control.

# Android SDK location (set automatically by Android Studio)
sdk.dir=/Users/YOUR_USERNAME/Library/Android/sdk

# Supabase credentials — find these in your Supabase project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
